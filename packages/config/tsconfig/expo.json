{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "jsx": "react-native",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "allowJs": true,
    "noEmit": true,
    "types": ["expo", "node"]
  }
}
