{
  "name": "@smartshopper/scraper",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "scrape": "tsx src/cli.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@smartshopper/types": "workspace:*",
    "@supabase/supabase-js": "^2.45.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@smartshopper/config": "workspace:*",
    "@types/node": "^22.10.5",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
