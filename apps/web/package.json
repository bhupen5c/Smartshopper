{
  "name": "@smartshopper/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "unset __NEXT_PRIVATE_STANDALONE_CONFIG __NEXT_PRIVATE_RENDER_WORKER_CONFIG; next dev --turbo",
