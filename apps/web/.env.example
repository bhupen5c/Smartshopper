# NextAuth
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Admin credentials
ADMIN_EMAIL=admin@smartshopper.app
ADMIN_PASSWORD_HASH=$2b$12$m794wrYenStwS1yzYAB/xOpXZmjuJn43XjBAgLKD76fu90ZXIaMhy

# ─── Supabase (live pricing data) ───
# All Supabase access is server-side, so use plain runtime vars (NOT
# NEXT_PUBLIC_* — those get inlined at build time and a redeploy can't
# fix a missing one). Project URL + anon (publishable) key.
SUPABASE_URL=https://bkxfnginzptwthypriub.supabase.co
SUPABASE_ANON_KEY=sb_publishable_rgbYJ7LlrlBnJGUA7_4l_w_GPP8XUgS

# Service-role key — server-side only. Used by the cron scraper to write
# to `prices` and `scrape_runs`. NEVER commit a real value. Get it from
# Supabase dashboard > Project settings > API Keys > service_role.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Gemini (price scraping) ───
# Optional. When set, the daily scraper uses Gemini to parse retailer
# pages and catalogue PDFs. Without it, the scraper falls back to direct
# JSON endpoints where available; otherwise it skips that retailer.
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Cron / queue ───
# Shared secret that `/api/cron/scrape-prices` verifies before kicking off
# a scrape. Vercel injects this when calling the cron endpoint.
CRON_SECRET=

# Upstash QStash — fans out per-retailer scrape jobs so each invocation
# fits in the Vercel function timeout. Free tier (500 messages/day) is
# enough for one daily fan-out across ~10 retailers.
# https://console.upstash.com/qstash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
